{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET all sessions",
      "method": "GET",
      "path": "/?all=true",
      "expectedStatus": 200,
      "expectedBody": {"sessions": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST send client text",
      "method": "POST",
      "path": "/",
      "body": {"session_id": "test-auto-001", "text": "Тест отправки", "from_role": "client"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET messages by session",
      "method": "GET",
      "path": "/?session_id=test-auto-001",
      "expectedStatus": 200,
      "expectedBody": {"messages": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST mark read",
      "method": "POST",
      "path": "/",
      "body": {"session_id": "test-auto-001", "mark_read": true},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST empty text returns error",
      "method": "POST",
      "path": "/",
      "body": {"session_id": "test-auto-001", "text": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "text or image required"},
      "bodyMatcher": "partial"
    }
  ]
}
