{
  "tests": [
    {
      "name": "Health check",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"status": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Lead form",
      "method": "POST",
      "path": "/",
      "headers": {"Content-Type": "application/json"},
      "body": {"action": "lead", "from": "Москва", "to": "Тула", "phone": "+79991234567", "name": "Тест", "tariff": "Комфорт+", "utm": {"utm_source": "test"}},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Callback form",
      "method": "POST",
      "path": "/",
      "headers": {"Content-Type": "application/json"},
      "body": {"action": "callback", "phone": "+79991234567", "utm": {"utm_source": "test"}},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Lead without phone fails",
      "method": "POST",
      "path": "/",
      "headers": {"Content-Type": "application/json"},
      "body": {"action": "lead", "from": "Москва", "to": "Тула"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}